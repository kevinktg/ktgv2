{
    "mcpServers":  {
                       "figma":  {
                                     "command":  "npx",
                                     "args":  [
                                                  "-y",
                                                  "figma-developer-mcp"
                                              ],
                                     "env":  {
                                                 "FIGMA_API_KEY":  ""
                                             }
                                 },
                       "vercel":  {
                                      "command":  "npx",
                                      "args":  [
                                                   "-y",
                                                   "@vercel/mcp-adapter"
                                               ],
                                      "env":  {
                                                  "VERCEL_API_KEY":  ""
                                              }
                                  },
                       "in-memoria":  {
                                          "command":  "npx",
                                          "args":  [
                                                       "-y",
                                                       "in-memoria",
                                                       "server"
                                                   ]
                                      },
                       "next-devtools":  {
                                             "command":  "npx",
                                             "args":  [
                                                          "-y",
                                                          "next-devtools-mcp@latest"
                                                      ]
                                         },
                       "serena":  {
                                      "command":  "uvx",
                                      "args":  [
                                                   "--from",
                                                   "git+https://github.com/oraios/serena",
                                                   "serena",
                                                   "start-mcp-server",
                                                   "--context",
                                                   "claude-code",
                                                   "--project",
                                                   "D:/projects/sites/ktgv2"
                                               ]
                                  },
                       "mem0":  {
                                    "command":  "npx",
                                    "args":  [
                                                 "-y",
                                                 "@mem0/mcp-server"
                                             ],
                                    "env":  {
                                                "MEM0_API_KEY":  "",
                                                "MEM0_USER_ID":  "kevinktg"
                                            }
                                },
                       "pal":  {
                                   "command":  "uvx",
                                   "args":  [
                                                "--from",
                                                "git+https://github.com/BeehiveInnovations/pal-mcp-server.git",
                                                "pal-mcp-server"
                                            ],
                                   "env":  {
                                               "GEMINI_API_KEY":  "",
                                               "DEFAULT_MODEL":  "auto"
                                           }
                               },
                       "jcodemunch":  {
                                          "command":  "uvx",
                                          "args":  [
                                                       "--from",
                                                       "git+https://github.com/JohnGravelle/jcodemunch-mcp.git",
                                                       "jcodemunch-mcp"
                                                   ]
                                      },
                       "gsap-master":  {
                                           "command":  "npx",
                                           "args":  [
                                                        "-y",
                                                        "bruzethegreat-gsap-master-mcp-server@latest"
                                                    ]
                                       }
                   }
}
